{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["responseCode", "brands"],
  "properties": {
    "responseCode": {
      "type": "integer"
    },
    "brands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "brand"],
        "properties": {
          "id": {"type": "integer"},
          "brand": {"type": "string"}}}}}}
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["responseCode", "products"],
  "properties": {
    "responseCode": {
      "type": "integer"
    },
    "products": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "price", "brand", "category"],
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "price": {"type": "string"},
          "brand": {"type": "string"},
          "category": {
            "type": "object",
            "properties": {
              "usertype": {
                "type": "object",
                "properties": {
                  "usertype": {"type": "string"}
                }
              },
              "category": {"type": "string"}
            }
          }
        }
      }
    }
  }
}